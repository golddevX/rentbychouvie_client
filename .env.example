# PostgreSQL dùng chung với hệ thống admin/backend.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rental_fashion"

# Tùy chọn: ID nhân viên nhận các đơn đặt thuê trực tiếp từ website.
# Nếu bỏ trống, Client chọn nhân viên đang hoạt động đầu tiên thuộc nhóm SUPER_ADMIN/MANAGER/SALES.
PUBLIC_BOOKING_CREATED_BY_ID=

# URL public của website Vercel.
NEXT_PUBLIC_SITE_URL=https://your-storefront.vercel.app

# Tùy chọn: API key của AI provider thật.
REPLICATE_API_TOKEN=
REPLICATE_IMAGE_MODEL=google/nano-banana-pro

# Chỉ dùng khi phát triển localhost. Production nên dùng UPLOAD_PROVIDER_KEY.
LOCAL_UPLOAD_ROOT=.local-uploads

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
